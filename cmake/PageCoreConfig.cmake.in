@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(CURL)
find_dependency(ZLIB)

set(PAGECORE_ENABLE_RENDERING @PAGECORE_ENABLE_RENDERING@)
set(PAGECORE_ENABLE_SVG @PAGECORE_ENABLE_SVG@)

function(_pagecore_import_static_dependency target file_name)
    if(TARGET "${target}")
        return()
    endif()

    add_library("${target}" STATIC IMPORTED)
    set_target_properties("${target}" PROPERTIES
        IMPORTED_LOCATION "${PACKAGE_PREFIX_DIR}/@PAGECORE_INSTALL_DEPSDIR@/${file_name}"
    )
endfunction()

_pagecore_import_static_dependency(PageCore::lexbor_static "@PAGECORE_LEXBOR_STATIC_FILE@")
_pagecore_import_static_dependency(PageCore::qjs "@PAGECORE_QJS_STATIC_FILE@")

if(PAGECORE_ENABLE_RENDERING)
    _pagecore_import_static_dependency(PageCore::litehtml "@PAGECORE_LITEHTML_STATIC_FILE@")
    _pagecore_import_static_dependency(PageCore::woff2common "@PAGECORE_WOFF2COMMON_STATIC_FILE@")
    _pagecore_import_static_dependency(PageCore::woff2dec "@PAGECORE_WOFF2DEC_STATIC_FILE@")
    set_property(TARGET PageCore::woff2dec APPEND PROPERTY
        INTERFACE_LINK_LIBRARIES PageCore::woff2common
    )
    # gumbo is only bundled when litehtml provided it (the install is conditional);
    # import and link it only if the archive was actually installed, so consumers
    # never reference a non-existent libgumbo.a.
    set(_pagecore_gumbo_name "@PAGECORE_GUMBO_STATIC_FILE@")
    if(_pagecore_gumbo_name)
        set(_pagecore_gumbo_file "${PACKAGE_PREFIX_DIR}/@PAGECORE_INSTALL_DEPSDIR@/${_pagecore_gumbo_name}")
        if(EXISTS "${_pagecore_gumbo_file}")
            _pagecore_import_static_dependency(PageCore::gumbo "${_pagecore_gumbo_name}")
            set_property(TARGET PageCore::litehtml APPEND PROPERTY
                INTERFACE_LINK_LIBRARIES PageCore::gumbo
            )
        endif()
    endif()

    if(PAGECORE_ENABLE_SVG)
        _pagecore_import_static_dependency(PageCore::lunasvg "@PAGECORE_LUNASVG_STATIC_FILE@")
        _pagecore_import_static_dependency(PageCore::plutovg "@PAGECORE_PLUTOVG_STATIC_FILE@")
        set_property(TARGET PageCore::lunasvg APPEND PROPERTY
            INTERFACE_LINK_LIBRARIES PageCore::plutovg
        )
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/PageCoreTargets.cmake")

set(PageCore_FOUND TRUE)
check_required_components(PageCore)
